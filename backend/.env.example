# Copy to backend/.env and fill in real values (ONE line per variable)

PORT=5000

# MongoDB Atlas (single line — include database name before ?)
# Example:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/codeclimb?retryWrites=true&w=majority
MONGODB_URI=

FIREBASE_PROJECT_ID=code-climb-auth
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

JUDGE0_API_URL=https://ce.judge0.com/submissions?base64_encoded=false&wait=true
CLIENT_ORIGIN=http://localhost:5173
